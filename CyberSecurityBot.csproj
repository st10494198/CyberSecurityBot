  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="Services\AudioPlayer.cs" />
  </ItemGroup>

  <ItemGroup>
    <None Include="Services\AudioPlayer.cs" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="System.Windows.Extensions" Version="10.0.5" />
  </ItemGroup>

  <ItemGroup>
    <None Update="Assets\ascii-art.txt">
